[Unit]
Description=ROV Bottomside Service
Wants=network-online.target
After=network-online.target systemd-modules-load.service
StartLimitIntervalSec=0

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/home/pi/
Environment=VIRTUAL_ENV=/home/pi/venv
Environment=PATH=/home/pi/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
# Wait up to 30 seconds for I2C to appear before launching hardware init.
ExecStartPre=/bin/sh -c 'for i in $(seq 1 30); do [ -e /dev/i2c-1 ] && exit 0; sleep 1; done; echo "[systemd] /dev/i2c-1 not ready"; exit 1'
ExecStart=/home/pi/venv/bin/python /home/pi/rov_bottomside.py
Restart=on-failure
RestartSec=5
TimeoutStartSec=45
TimeoutStopSec=15
KillSignal=SIGINT
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=false
PrivateTmp=true

[Install]
WantedBy=multi-user.target
